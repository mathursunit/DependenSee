<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ctrl="clr-namespace:ServiceMap.App.Controls"
             x:Class="ServiceMap.App.Controls.FilterHeader"
             x:CompileBindings="False">
    <DockPanel LastChildFill="False">
        <TextBlock Text="{Binding Header}" VerticalAlignment="Center" DockPanel.Dock="Left" />
        <Button DockPanel.Dock="Right" Padding="4,0" Margin="6,0,0,0"
                Background="Transparent" BorderThickness="0" FontSize="9"
                Content="&#x25BC;" ToolTip.Tip="Filter this column"
                Foreground="{Binding IsActive, Converter={x:Static ctrl:FunnelBrush.Instance}}">
            <Button.Flyout>
                <Flyout Placement="Bottom">
                    <StackPanel Width="230" Spacing="6">
                        <TextBox Watermark="Search values…" Text="{Binding Search}" />
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <Button Content="Select all" Command="{Binding SelectAllCommand}" />
                            <Button Content="Clear" Command="{Binding ClearAllCommand}" />
                        </StackPanel>
                        <ScrollViewer MaxHeight="260" VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding FilteredValues}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <CheckBox IsChecked="{Binding IsChecked}" Content="{Binding Display}" />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </StackPanel>
                </Flyout>
            </Button.Flyout>
        </Button>
    </DockPanel>
</UserControl>
