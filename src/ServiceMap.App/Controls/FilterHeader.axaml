<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ctrl="clr-namespace:ServiceMap.App.Controls"
             x:Class="ServiceMap.App.Controls.FilterHeader"
             x:CompileBindings="False">
    <!-- Funnel button is docked FIRST so it always reserves space and never
         clips on narrow columns; the title fills the rest and trims if needed. -->
    <DockPanel LastChildFill="True">
        <Button DockPanel.Dock="Right" Padding="5,1" Margin="6,0,0,0"
                VerticalAlignment="Center"
                Background="#E5E7EB" BorderBrush="#9CA3AF" BorderThickness="1"
                CornerRadius="3" FontSize="10"
                ToolTip.Tip="Filter this column">
            <StackPanel Orientation="Horizontal" Spacing="2">
                <TextBlock Text="&#x25BC;"
                           Foreground="{Binding IsActive, Converter={x:Static ctrl:FunnelBrush.Instance}}" />
            </StackPanel>
            <Button.Flyout>
                <Flyout Placement="Bottom">
                    <StackPanel Width="230" Spacing="6">
                        <TextBlock Text="{Binding Header}" FontWeight="SemiBold" />
                        <TextBox Watermark="Search values&#x2026;" Text="{Binding Search}" />
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <Button Content="Select all" Command="{Binding SelectAllCommand}" />
                            <Button Content="Clear" Command="{Binding ClearAllCommand}" />
                        </StackPanel>
                        <ScrollViewer MaxHeight="260" VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding FilteredValues}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <CheckBox IsChecked="{Binding IsChecked}" Content="{Binding Display}" />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </StackPanel>
                </Flyout>
            </Button.Flyout>
        </Button>
        <TextBlock Text="{Binding Header}" VerticalAlignment="Center"
                   TextTrimming="CharacterEllipsis" />
    </DockPanel>
</UserControl>
