<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:ServiceMap.App.ViewModels"
        xmlns:ctrl="clr-namespace:ServiceMap.App.Controls"
        x:Class="ServiceMap.App.Views.MainWindow"
        Width="1180" Height="740"
        MinWidth="880" MinHeight="540"
        Title="{Binding Title}">

    <Design.DataContext>
        <vm:MainWindowViewModel />
    </Design.DataContext>

    <DockPanel>
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="_Help">
                <MenuItem Header="_About Carrier DependenSee" Click="OnAboutClick" />
            </MenuItem>
        </Menu>
        <Border DockPanel.Dock="Top" Background="#1F2937" Padding="16,10">
            <DockPanel LastChildFill="False">
                <StackPanel Orientation="Horizontal" Spacing="12" DockPanel.Dock="Left">
                    <TextBlock Text="Carrier DependenSee" FontSize="18" FontWeight="Bold"
                               Foreground="White" VerticalAlignment="Center" />
                    <TextBlock Text="See what connects." FontSize="13"
                               Foreground="#9CA3AF" VerticalAlignment="Center" />
                    <Border CornerRadius="3" Padding="8,2" VerticalAlignment="Center"
                            Background="#065F46" IsVisible="{Binding IsLocalActive}">
                        <TextBlock Text="● LIVE — this machine" Foreground="#A7F3D0" FontSize="11" FontWeight="Bold" />
                    </Border>
                    <Border CornerRadius="3" Padding="8,2" VerticalAlignment="Center"
                            Background="#92400E" IsVisible="{Binding IsRemoteActive}">
                        <TextBlock Text="◆ SNAPSHOT — imported/remote" Foreground="#FDE68A" FontSize="11" FontWeight="Bold" />
                    </Border>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="8" DockPanel.Dock="Right" VerticalAlignment="Center">
                    <TextBlock Text="Machine:" Foreground="#9CA3AF" VerticalAlignment="Center" />
                    <ComboBox MinWidth="230" ItemsSource="{Binding MachineOptions}"
                              SelectedItem="{Binding SelectedMachineOption}" />
                </StackPanel>
            </DockPanel>
        </Border>
        <Border DockPanel.Dock="Top" Background="#DBEAFE" BorderBrush="#3B82F6" BorderThickness="0,0,0,1"
                Padding="16,6" IsVisible="{Binding !ThisMachineAvailable}">
            <TextBlock Text="{Binding ModeBanner}" Foreground="#1E40AF"
                       VerticalAlignment="Center" TextWrapping="Wrap" />
        </Border>
        <Border DockPanel.Dock="Top" Background="#FEF3C7" BorderBrush="#F59E0B" BorderThickness="0,0,0,1"
                Padding="16,6" IsVisible="{Binding IsRemoteActive}">
            <TextBlock Text="{Binding ActiveMachineBanner}" Foreground="#92400E"
                       VerticalAlignment="Center" TextWrapping="Wrap" />
        </Border>

        <TabControl Margin="8" SelectedIndex="{Binding SelectedTabIndex}">

            <!-- DASHBOARD -->
            <TabItem Header="Dashboard" IsVisible="{Binding ThisMachineAvailable}">
                <DockPanel>
                    <Border DockPanel.Dock="Top" Background="#F3F4F6"
                            Padding="12,8" Margin="0,0,0,8" CornerRadius="4">
                        <StackPanel Orientation="Horizontal" Spacing="24">
                            <StackPanel>
                                <TextBlock Text="Services" FontSize="11" Foreground="#6B7280" />
                                <TextBlock Text="{Binding Dashboard.ServiceCount}" FontSize="20" FontWeight="Bold" />
                            </StackPanel>
                            <StackPanel>
                                <TextBlock Text="Listeners" FontSize="11" Foreground="#6B7280" />
                                <TextBlock Text="{Binding Dashboard.ListenerCount}" FontSize="20" FontWeight="Bold" />
                            </StackPanel>
                            <StackPanel>
                                <TextBlock Text="Inbound" FontSize="11" Foreground="#6B7280" />
                                <TextBlock Text="{Binding Dashboard.InboundCount}" FontSize="20" FontWeight="Bold" Foreground="#059669" />
                            </StackPanel>
                            <StackPanel>
                                <TextBlock Text="Outbound" FontSize="11" Foreground="#6B7280" />
                                <TextBlock Text="{Binding Dashboard.OutboundCount}" FontSize="20" FontWeight="Bold" Foreground="#2563EB" />
                            </StackPanel>
                            <TextBlock Text="{Binding Dashboard.StatusLine}" VerticalAlignment="Center"
                                       Foreground="#374151" TextWrapping="Wrap" />
                            <CheckBox Content="Hide standard Windows services" VerticalAlignment="Center"
                                      IsChecked="{Binding Dashboard.HideStandardServices}" />
                        </StackPanel>
                    </Border>

                    <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,*,Auto,*">
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Registered services" FontWeight="SemiBold" Margin="2,0,0,4" />
                        <DataGrid Grid.Row="1" Grid.Column="0" Margin="0,0,4,8" x:CompileBindings="False"
                                  ItemsSource="{Binding Dashboard.Services}" IsReadOnly="True" CanUserResizeColumns="True"
                                  GridLinesVisibility="Horizontal" CanUserSortColumns="True">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Display name" Binding="{Binding DisplayName}" Width="2*" />
                                <DataGridTextColumn Header="State" Binding="{Binding State}" Width="Auto" />
                                <DataGridTextColumn Header="Start" Binding="{Binding StartMode}" Width="Auto" />
                                <DataGridTextColumn Header="PID" Binding="{Binding ProcessId}" Width="Auto" />
                            </DataGrid.Columns>
                        </DataGrid>

                        <TextBlock Grid.Row="0" Grid.Column="1" Text="Listening endpoints" FontWeight="SemiBold" Margin="6,0,0,4" />
                        <DataGrid Grid.Row="1" Grid.Column="1" Margin="4,0,0,8" x:CompileBindings="False"
                                  ItemsSource="{Binding Dashboard.Listeners}" IsReadOnly="True" CanUserResizeColumns="True"
                                  GridLinesVisibility="Horizontal" CanUserSortColumns="True">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Proto" Binding="{Binding Protocol}" Width="Auto" />
                                <DataGridTextColumn Header="Local address" Binding="{Binding LocalAddress}" Width="170" />
                                <DataGridTextColumn Header="Port" Binding="{Binding LocalPort}" Width="80" />
                                <DataGridTextColumn Header="Service" Binding="{Binding ServiceOrProcess}" Width="*" />
                                <DataGridTextColumn Header="Process" Binding="{Binding ProcessName}" Width="140" />
                                <DataGridTextColumn Header="PID" Binding="{Binding ProcessId}" Width="Auto" />
                            </DataGrid.Columns>
                        </DataGrid>

                        <TextBlock Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" Text="Active connections" FontWeight="SemiBold" Margin="2,0,0,4" />
                        <DataGrid Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2" x:CompileBindings="False"
                                  ItemsSource="{Binding Dashboard.ActiveConnections}" IsReadOnly="True" CanUserResizeColumns="True"
                                  GridLinesVisibility="Horizontal" CanUserSortColumns="True">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Proto" Binding="{Binding Protocol}" Width="Auto" />
                                <DataGridTextColumn Header="Direction" Binding="{Binding Direction}" Width="Auto" />
                                <DataGridTextColumn Header="Scope" Binding="{Binding RemoteScope}" Width="Auto" />
                                <DataGridTextColumn Header="Local address" Binding="{Binding LocalAddress}" Width="150" />
                                <DataGridTextColumn Header="L.Port" Binding="{Binding LocalPort}" Width="75" />
                                <DataGridTextColumn Header="Remote address" Binding="{Binding RemoteAddress}" Width="150" />
                                <DataGridTextColumn Header="R.Port" Binding="{Binding RemotePort}" Width="75" />
                                <DataGridTextColumn Header="Service" Binding="{Binding ServiceOrProcess}" Width="*" />
                                <DataGridTextColumn Header="Process" Binding="{Binding ProcessName}" Width="140" />
                                <DataGridTextColumn Header="PID" Binding="{Binding ProcessId}" Width="Auto" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </DockPanel>
            </TabItem>

            <!-- HISTORY -->
            <TabItem Header="History" IsVisible="{Binding ThisMachineAvailable}">
                <DockPanel>
                    <Border DockPanel.Dock="Top" Background="#F3F4F6" Padding="12,8" Margin="0,0,0,8" CornerRadius="4">
                        <StackPanel Spacing="8">
                            <WrapPanel>
                                <StackPanel Margin="0,0,12,0">
                                    <TextBlock Text="Process contains" FontSize="11" Foreground="#6B7280" />
                                    <TextBox Width="140" Text="{Binding History.ProcessNameFilter}" />
                                </StackPanel>
                                <StackPanel Margin="0,0,12,0">
                                    <TextBlock Text="Remote contains" FontSize="11" Foreground="#6B7280" />
                                    <TextBox Width="140" Text="{Binding History.RemoteAddressFilter}" />
                                </StackPanel>
                                <StackPanel Margin="0,0,12,0">
                                    <TextBlock Text="Process excludes" FontSize="11" Foreground="#6B7280" />
                                    <TextBox Width="140" Text="{Binding History.ProcessNotContains}" />
                                </StackPanel>
                                <StackPanel Margin="0,0,12,0">
                                    <TextBlock Text="Remote excludes" FontSize="11" Foreground="#6B7280" />
                                    <TextBox Width="140" Text="{Binding History.RemoteNotContains}" />
                                </StackPanel>
                                <StackPanel Margin="0,0,12,0">
                                    <TextBlock Text="Local port" FontSize="11" Foreground="#6B7280" />
                                    <TextBox Width="80" Text="{Binding History.LocalPortFilter}" />
                                </StackPanel>
                                <StackPanel Margin="0,0,12,0">
                                    <TextBlock Text="Local port excludes" FontSize="11" Foreground="#6B7280" />
                                    <TextBox Width="80" Text="{Binding History.LocalPortNotFilter}" />
                                </StackPanel>
                                <StackPanel Margin="0,0,12,0">
                                    <TextBlock Text="Local contains" FontSize="11" Foreground="#6B7280" />
                                    <TextBox Width="140" Text="{Binding History.LocalAddressFilter}" />
                                </StackPanel>
                                <StackPanel Margin="0,0,12,0">
                                    <TextBlock Text="Local excludes" FontSize="11" Foreground="#6B7280" />
                                    <TextBox Width="140" Text="{Binding History.LocalNotContains}" />
                                </StackPanel>
                                <StackPanel Margin="0,0,12,0">
                                    <TextBlock Text="Protocol" FontSize="11" Foreground="#6B7280" />
                                    <ComboBox Width="85" ItemsSource="{Binding History.ProtocolOptions}"
                                              SelectedItem="{Binding History.SelectedProtocol}" />
                                </StackPanel>
                                <StackPanel Margin="0,0,12,0">
                                    <TextBlock Text="Direction" FontSize="11" Foreground="#6B7280" />
                                    <ComboBox Width="100" ItemsSource="{Binding History.DirectionOptions}"
                                              SelectedItem="{Binding History.SelectedDirection}" />
                                </StackPanel>
                                <StackPanel Margin="0,0,12,0">
                                    <TextBlock Text="Family" FontSize="11" Foreground="#6B7280" />
                                    <ComboBox Width="85" ItemsSource="{Binding History.FamilyOptions}"
                                              SelectedItem="{Binding History.SelectedFamily}" />
                                </StackPanel>
                                <StackPanel Margin="0,0,12,0">
                                    <TextBlock Text="Scope" FontSize="11" Foreground="#6B7280" />
                                    <ComboBox Width="110" ItemsSource="{Binding History.ScopeOptions}"
                                              SelectedItem="{Binding History.SelectedScope}" />
                                </StackPanel>
                                <StackPanel Margin="0,0,12,0">
                                    <TextBlock Text="Hours back" FontSize="11" Foreground="#6B7280" />
                                    <NumericUpDown Width="105" Minimum="1" Maximum="8760" Value="{Binding History.HoursBack}" />
                                </StackPanel>
                                <StackPanel Margin="0,0,12,0">
                                    <TextBlock Text="Row limit" FontSize="11" Foreground="#6B7280" />
                                    <NumericUpDown Width="115" Minimum="100" Maximum="1000000" Increment="500" Value="{Binding History.Limit}" />
                                </StackPanel>
                            </WrapPanel>

                            <WrapPanel>
                                <CheckBox Content="Unique flows only" IsChecked="{Binding History.UniqueOnly}" Margin="0,0,16,0" />
                                <CheckBox Content="Hide ephemeral ports" IsChecked="{Binding History.ExcludeEphemeral}" Margin="0,0,16,0" />
                                <CheckBox Content="Hide same-subnet" IsChecked="{Binding History.HideSameSubnet}" Margin="0,0,16,0" />
                                <Button Content="Run query" Command="{Binding History.RunQueryCommand}" Margin="0,0,8,0" />
                                <Button Content="Export CSV" Command="{Binding History.ExportCsvCommand}" Margin="0,0,8,0" />
                                <Button Content="Export JSON" Command="{Binding History.ExportJsonCommand}" Margin="0,0,16,0" />
                                <Button Content="Export firewall PDF" Command="{Binding History.ExportFirewallPdfCommand}"
                                        Background="#1F2937" Foreground="White" Margin="0,0,10,0" />
                                <Button Content="Export dossier" Command="{Binding ExportDossierCommand}"
                                        IsEnabled="{Binding !IsExporting}" />
                                <Button Content="Save baseline" Command="{Binding SaveBaselineCommand}" />
                                <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center"
                                            IsVisible="{Binding IsExporting}">
                                    <ProgressBar Width="140" Minimum="0" Maximum="100"
                                                 Value="{Binding ExportProgress}" />
                                    <TextBlock Text="{Binding ExportStage}" FontSize="11" Foreground="#6B7280"
                                               VerticalAlignment="Center" />
                                </StackPanel>
                                <CheckBox Content="Resolve names" IsChecked="{Binding History.ResolveHostnames}" Margin="0,0,12,0"
                                          VerticalAlignment="Center" />
                                <CheckBox Content="Summarize /24" IsChecked="{Binding History.SummarizeSources}"
                                          VerticalAlignment="Center" />
                            </WrapPanel>
                            <TextBlock Text="{Binding History.ResultSummary}" Foreground="#374151" TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>

                    <!-- Raw samples grid -->
                    <DataGrid x:CompileBindings="False" IsVisible="{Binding History.ShowRaw}"
                              ItemsSource="{Binding History.Results}" IsReadOnly="True" CanUserResizeColumns="True"
                              GridLinesVisibility="Horizontal" CanUserSortColumns="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Timestamp (local)"
                                Binding="{Binding TimestampLocal}" Width="Auto" />
                            <DataGridTextColumn Binding="{Binding Protocol}" Width="Auto">
                                <DataGridTextColumn.Header>
                                    <ctrl:FilterHeader DataContext="{Binding History.ProtocolCol}" />
                                </DataGridTextColumn.Header>
                            </DataGridTextColumn>
                            <DataGridTextColumn Binding="{Binding Direction}" Width="Auto">
                                <DataGridTextColumn.Header>
                                    <ctrl:FilterHeader DataContext="{Binding History.DirectionCol}" />
                                </DataGridTextColumn.Header>
                            </DataGridTextColumn>
                            <DataGridTextColumn Binding="{Binding RemoteScope}" Width="Auto">
                                <DataGridTextColumn.Header>
                                    <ctrl:FilterHeader DataContext="{Binding History.ScopeCol}" />
                                </DataGridTextColumn.Header>
                            </DataGridTextColumn>
                            <DataGridTextColumn Binding="{Binding LocalAddress}" Width="150">
                                <DataGridTextColumn.Header>
                                    <ctrl:FilterHeader DataContext="{Binding History.LocalAddrCol}" />
                                </DataGridTextColumn.Header>
                            </DataGridTextColumn>
                                <DataGridTextColumn Binding="{Binding LocalPort}" Width="75">
                                <DataGridTextColumn.Header>
                                    <ctrl:FilterHeader DataContext="{Binding History.LocalPortCol}" />
                                </DataGridTextColumn.Header>
                            </DataGridTextColumn>
                            <DataGridTextColumn Binding="{Binding RemoteAddress}" Width="150">
                                <DataGridTextColumn.Header>
                                    <ctrl:FilterHeader DataContext="{Binding History.RemoteAddrCol}" />
                                </DataGridTextColumn.Header>
                            </DataGridTextColumn>
                                <DataGridTextColumn Binding="{Binding RemotePort}" Width="75">
                                <DataGridTextColumn.Header>
                                    <ctrl:FilterHeader DataContext="{Binding History.RemotePortCol}" />
                                </DataGridTextColumn.Header>
                            </DataGridTextColumn>
                            <DataGridTextColumn Binding="{Binding ServiceOrProcess}" Width="*">
                                <DataGridTextColumn.Header>
                                    <ctrl:FilterHeader DataContext="{Binding History.ServiceCol}" />
                                </DataGridTextColumn.Header>
                            </DataGridTextColumn>
                                <DataGridTextColumn Binding="{Binding ProcessName}" Width="140">
                                <DataGridTextColumn.Header>
                                    <ctrl:FilterHeader DataContext="{Binding History.ProcessCol}" />
                                </DataGridTextColumn.Header>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="PID" Binding="{Binding ProcessId}" Width="Auto" />
                        </DataGrid.Columns>
                    </DataGrid>

                    <!-- Unique flows grid -->
                    <DataGrid x:CompileBindings="False" IsVisible="{Binding History.ShowUnique}"
                              ItemsSource="{Binding History.UniqueResults}" IsReadOnly="True" CanUserResizeColumns="True"
                              GridLinesVisibility="Horizontal" CanUserSortColumns="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="First seen"
                                Binding="{Binding FirstSeenLocal}" Width="Auto" />
                            <DataGridTextColumn Header="Last seen"
                                Binding="{Binding LastSeenLocal}" Width="Auto" />
                            <DataGridTextColumn Header="Count" Binding="{Binding SampleCount}" Width="Auto" />
                            <DataGridTextColumn Binding="{Binding Protocol}" Width="Auto">
                                <DataGridTextColumn.Header>
                                    <ctrl:FilterHeader DataContext="{Binding History.ProtocolCol}" />
                                </DataGridTextColumn.Header>
                            </DataGridTextColumn>
                            <DataGridTextColumn Binding="{Binding Direction}" Width="Auto">
                                <DataGridTextColumn.Header>
                                    <ctrl:FilterHeader DataContext="{Binding History.DirectionCol}" />
                                </DataGridTextColumn.Header>
                            </DataGridTextColumn>
                            <DataGridTextColumn Binding="{Binding RemoteScope}" Width="Auto">
                                <DataGridTextColumn.Header>
                                    <ctrl:FilterHeader DataContext="{Binding History.ScopeCol}" />
                                </DataGridTextColumn.Header>
                            </DataGridTextColumn>
                            <DataGridTextColumn Binding="{Binding LocalAddress}" Width="150">
                                <DataGridTextColumn.Header>
                                    <ctrl:FilterHeader DataContext="{Binding History.LocalAddrCol}" />
                                </DataGridTextColumn.Header>
                            </DataGridTextColumn>
                                <DataGridTextColumn Binding="{Binding LocalPort}" Width="75">
                                <DataGridTextColumn.Header>
                                    <ctrl:FilterHeader DataContext="{Binding History.LocalPortCol}" />
                                </DataGridTextColumn.Header>
                            </DataGridTextColumn>
                            <DataGridTextColumn Binding="{Binding RemoteAddress}" Width="150">
                                <DataGridTextColumn.Header>
                                    <ctrl:FilterHeader DataContext="{Binding History.RemoteAddrCol}" />
                                </DataGridTextColumn.Header>
                            </DataGridTextColumn>
                                <DataGridTextColumn Binding="{Binding RemotePort}" Width="75">
                                <DataGridTextColumn.Header>
                                    <ctrl:FilterHeader DataContext="{Binding History.RemotePortCol}" />
                                </DataGridTextColumn.Header>
                            </DataGridTextColumn>
                            <DataGridTextColumn Binding="{Binding ServiceOrProcess}" Width="*">
                                <DataGridTextColumn.Header>
                                    <ctrl:FilterHeader DataContext="{Binding History.ServiceCol}" />
                                </DataGridTextColumn.Header>
                            </DataGridTextColumn>
                                <DataGridTextColumn Binding="{Binding ProcessName}" Width="140">
                                <DataGridTextColumn.Header>
                                    <ctrl:FilterHeader DataContext="{Binding History.ProcessCol}" />
                                </DataGridTextColumn.Header>
                            </DataGridTextColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </TabItem>

            <!-- ANNOTATIONS -->
            <TabItem Header="Annotations">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Margin="2,0,0,6" Foreground="#374151"
                               Text="Tag processes, ports, and hosts with friendly names, owners, and criticality. These enrich the firewall PDF." />
                    <Border DockPanel.Dock="Bottom" Background="#F3F4F6" Padding="12" Margin="0,8,0,0" CornerRadius="4">
                        <StackPanel Spacing="8">
                            <WrapPanel>
                                <StackPanel Margin="0,0,12,0">
                                    <TextBlock Text="Kind" FontSize="11" Foreground="#6B7280" />
                                    <ComboBox Width="110" ItemsSource="{Binding Annotations.KindOptions}"
                                              SelectedItem="{Binding Annotations.SelectedKind}" />
                                </StackPanel>
                                <StackPanel Margin="0,0,12,0">
                                    <TextBlock Text="Key (process / port / host)" FontSize="11" Foreground="#6B7280" />
                                    <TextBox Width="200" Text="{Binding Annotations.Key}" />
                                </StackPanel>
                                <StackPanel Margin="0,0,12,0">
                                    <TextBlock Text="Friendly name" FontSize="11" Foreground="#6B7280" />
                                    <TextBox Width="200" Text="{Binding Annotations.FriendlyName}" />
                                </StackPanel>
                                <StackPanel Margin="0,0,12,0">
                                    <TextBlock Text="Owner" FontSize="11" Foreground="#6B7280" />
                                    <TextBox Width="150" Text="{Binding Annotations.Owner}" />
                                </StackPanel>
                                <StackPanel Margin="0,0,12,0">
                                    <TextBlock Text="Criticality" FontSize="11" Foreground="#6B7280" />
                                    <ComboBox Width="110" ItemsSource="{Binding Annotations.CriticalityOptions}"
                                              SelectedItem="{Binding Annotations.SelectedCriticality}" />
                                </StackPanel>
                            </WrapPanel>
                            <StackPanel>
                                <TextBlock Text="Notes" FontSize="11" Foreground="#6B7280" />
                                <TextBox Text="{Binding Annotations.Notes}" AcceptsReturn="True" Height="46" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Button Content="Save / Update" Command="{Binding Annotations.SaveCommand}"
                                        Background="#1F2937" Foreground="White" />
                                <Button Content="New" Command="{Binding Annotations.NewCommand}" />
                                <Button Content="Delete selected" Command="{Binding Annotations.DeleteCommand}" />
                                <TextBlock Text="{Binding Annotations.Status}" VerticalAlignment="Center" Foreground="#374151" />
                            </StackPanel>
                        </StackPanel>
                    </Border>
                    <DataGrid x:CompileBindings="False" ItemsSource="{Binding Annotations.Items}"
                              SelectedItem="{Binding Annotations.SelectedItem}" IsReadOnly="True" CanUserResizeColumns="True"
                              GridLinesVisibility="Horizontal" CanUserSortColumns="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Kind" Binding="{Binding Kind}" Width="Auto" />
                            <DataGridTextColumn Header="Key" Binding="{Binding Key}" Width="*" />
                            <DataGridTextColumn Header="Friendly name" Binding="{Binding FriendlyName}" Width="*" />
                            <DataGridTextColumn Header="Owner" Binding="{Binding Owner}" Width="*" />
                            <DataGridTextColumn Header="Criticality" Binding="{Binding Criticality}" Width="Auto" />
                            <DataGridTextColumn Header="Notes" Binding="{Binding Notes}" Width="2*" />
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </TabItem>

            <!-- MAP -->
            <TabItem Header="Map" IsVisible="{Binding ThisMachineAvailable}">
                <DockPanel>
                    <Border DockPanel.Dock="Top" Background="#F3F4F6" Padding="12,8" Margin="0,0,0,8" CornerRadius="4">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="Hours back" FontSize="11" Foreground="#6B7280" VerticalAlignment="Center" Margin="8,0,0,0" />
                            <NumericUpDown Width="120" Minimum="1" Maximum="8760" Value="{Binding Map.HoursBack}" />
                            <TextBlock Text="Max peers" FontSize="11" Foreground="#6B7280" VerticalAlignment="Center" Margin="8,0,0,0" />
                            <NumericUpDown Width="100" Minimum="5" Maximum="200" Value="{Binding Map.MaxPeers}" />
                            <Button Content="Refresh map" Command="{Binding Map.RefreshCommand}" Background="#1F2937" Foreground="White" />
                            <TextBlock Text="{Binding Map.Status}" VerticalAlignment="Center" Foreground="#374151" />
                        </StackPanel>
                    </Border>
                    <Border BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="4">
                        <ctrl:DependencyMapControl Nodes="{Binding Map.Nodes}" Edges="{Binding Map.Edges}" />
                    </Border>
                </DockPanel>
            </TabItem>

            <!-- REMOTE -->
            <TabItem Header="Remote">
                <DockPanel>
                    <Border DockPanel.Dock="Top" Background="#F3F4F6" Padding="12,8" Margin="0,0,0,8" CornerRadius="4">
                        <StackPanel Spacing="8">
                            <TextBlock Text="Agentless remote collection — gather services and connections from other servers without installing anything on them. Windows uses WinRM/PowerShell Remoting; Linux uses SSH."
                                       Foreground="#374151" TextWrapping="Wrap" />
                            <WrapPanel>
                                <StackPanel Margin="0,0,12,0">
                                    <TextBlock Text="Hosts / range / CIDR" FontSize="11" Foreground="#6B7280" />
                                    <TextBox Width="320" Height="52" AcceptsReturn="True" TextWrapping="Wrap"
                                             Watermark="10.0.0.10, 10.0.0.20-40, 10.1.0.0/24, server01"
                                             Text="{Binding Remote.Targets}" />
                                </StackPanel>
                                <StackPanel Margin="0,0,12,0">
                                    <TextBlock Text="OS / transport" FontSize="11" Foreground="#6B7280" />
                                    <ComboBox Width="150" ItemsSource="{Binding Remote.OsOptions}"
                                              SelectedItem="{Binding Remote.SelectedOs}" />
                                    <TextBlock Text="Port (optional)" FontSize="11" Foreground="#6B7280" Margin="0,8,0,0" />
                                    <TextBox Width="150" Text="{Binding Remote.PortText}" Watermark="22 / 5985" />
                                </StackPanel>
                                <StackPanel Margin="0,0,12,0">
                                    <TextBlock Text="Username" FontSize="11" Foreground="#6B7280" />
                                    <TextBox Width="180" Text="{Binding Remote.Username}" Watermark="DOMAIN\user or root" />
                                    <TextBlock Text="Password" FontSize="11" Foreground="#6B7280" Margin="0,8,0,0" />
                                    <TextBox Width="180" Text="{Binding Remote.Password}" PasswordChar="*" />
                                </StackPanel>
                                <StackPanel Margin="0,0,12,0">
                                    <TextBlock Text="SSH private key (optional)" FontSize="11" Foreground="#6B7280" />
                                    <TextBox Width="220" Text="{Binding Remote.PrivateKeyPath}" Watermark="C:\keys\id_rsa" />
                                    <TextBlock Text="Max parallel" FontSize="11" Foreground="#6B7280" Margin="0,8,0,0" />
                                    <NumericUpDown Width="120" Minimum="1" Maximum="64" Value="{Binding Remote.MaxParallel}" />
                                </StackPanel>
                                <StackPanel Margin="0,0,12,0">
                                    <TextBlock Text="Sweeps per scan" FontSize="11" Foreground="#6B7280" />
                                    <NumericUpDown Width="120" Minimum="1" Maximum="10" Value="{Binding Remote.SweepsPerScan}" />
                                    <TextBlock Text="Sweep delay (s)" FontSize="11" Foreground="#6B7280" Margin="0,8,0,0" />
                                    <NumericUpDown Width="120" Minimum="1" Maximum="60" Value="{Binding Remote.SweepDelaySeconds}" />
                                </StackPanel>
                            </WrapPanel>
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Button Content="Scan" Command="{Binding Remote.ScanCommand}"
                                        Background="#1F2937" Foreground="White"
                                        IsEnabled="{Binding !Remote.IsScanning}" />
                                <Button Content="Cancel" Command="{Binding Remote.CancelCommand}"
                                        IsEnabled="{Binding Remote.IsScanning}" />
                                <TextBlock Text="{Binding Remote.Status}" VerticalAlignment="Center" Foreground="#374151" TextWrapping="Wrap" />
                            </StackPanel>
                            <TextBlock FontSize="11" Foreground="#6B7280" TextWrapping="Wrap"
                                       Text="Credentials are used only for this scan and are not saved. Scan only systems you are authorized to access. WinRM must be enabled on Windows targets (Enable-PSRemoting; for workgroup hosts add them to TrustedHosts); SSH must be reachable on Linux targets." />
                            <Border BorderBrush="#E5E7EB" BorderThickness="0,1,0,0" Padding="0,8,0,0" Margin="0,4,0,0">
                                <StackPanel Spacing="6">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <TextBlock Text="Continuous: save as" VerticalAlignment="Center" FontSize="11" Foreground="#6B7280" />
                                        <TextBox Width="150" Text="{Binding Remote.ProfileName}" />
                                        <TextBlock Text="and run every" VerticalAlignment="Center" FontSize="11" Foreground="#6B7280" />
                                        <NumericUpDown Width="120" Minimum="1" Maximum="1440" Value="{Binding Remote.ScheduleMinutes}" />
                                        <TextBlock Text="min" VerticalAlignment="Center" FontSize="11" Foreground="#6B7280" />
                                        <Button Content="Schedule" Command="{Binding Remote.ScheduleCommand}" />
                                        <Button Content="Unschedule" Command="{Binding Remote.UnscheduleCommand}" />
                                    </StackPanel>
                                    <TextBlock Text="{Binding Remote.ScheduleStatus}" FontSize="11" Foreground="#374151" TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>
                    <Border BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="4">
                        <ListBox ItemsSource="{Binding Remote.Log}" FontFamily="Consolas,monospace" FontSize="12" />
                    </Border>
                </DockPanel>
            </TabItem>

            <!-- FLEET -->
            <TabItem Header="Fleet">
                <DockPanel>
                    <Border DockPanel.Dock="Top" Background="#F3F4F6" Padding="12,8" Margin="0,0,0,8" CornerRadius="4">
                        <StackPanel Spacing="8">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Button Content="Import database…" Command="{Binding Fleet.ImportMachineCommand}" />
                                <Button Content="Sync remote scans" Command="{Binding Fleet.SyncRemoteScansCommand}" />
                                <Button Content="Remove selected" Command="{Binding Fleet.RemoveMachineCommand}" />
                                <Button Content="View this server" Command="{Binding Fleet.ViewServerCommand}"
                                        Background="#1F2937" Foreground="White" />
                                <TextBlock Text="Hours back" FontSize="11" Foreground="#6B7280" VerticalAlignment="Center" Margin="8,0,0,0" />
                                <NumericUpDown Width="120" Minimum="1" Maximum="8760" Value="{Binding Fleet.HoursBack}" />
                                <Button Content="Refresh" Command="{Binding Fleet.RefreshCommand}" Background="#1F2937" Foreground="White" />
                                <TextBlock Text="Wave" FontSize="11" Foreground="#6B7280" VerticalAlignment="Center" Margin="8,0,0,0" />
                                <TextBox Width="120" Text="{Binding Fleet.WaveInput}" />
                                <Button Content="Assign wave" Command="{Binding Fleet.AssignWaveCommand}" />
                                <Button Content="Export dossier" Command="{Binding Fleet.ExportDossierCommand}"
                                        IsEnabled="{Binding !Fleet.IsExporting}" />
                                <Button Content="Export fleet workbook" Command="{Binding Fleet.ExportFleetWorkbookCommand}"
                                        IsEnabled="{Binding !Fleet.IsExporting}" />
                                <ProgressBar Width="140" Minimum="0" Maximum="100" VerticalAlignment="Center"
                                             IsVisible="{Binding Fleet.IsExporting}"
                                             Value="{Binding Fleet.ExportProgress}" />
                                <Button Content="Export server PDF" Command="{Binding Fleet.ExportServerPdfCommand}"
                                        Background="#1F2937" Foreground="White" Margin="16,0,0,0" />
                            </StackPanel>
                            <TextBlock Text="{Binding Fleet.Status}" Foreground="#374151" TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>
                    <Grid ColumnDefinitions="*,2*" RowDefinitions="Auto,*,Auto,*">
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Machines" FontWeight="SemiBold" Margin="2,0,0,4" />
                        <DataGrid Grid.Row="1" Grid.Column="0" Grid.RowSpan="3" Margin="0,0,6,0" x:CompileBindings="False"
                                  ItemsSource="{Binding Fleet.Machines}" SelectedItem="{Binding Fleet.SelectedMachine}"
                                  IsReadOnly="True" CanUserResizeColumns="True" GridLinesVisibility="Horizontal" CanUserSortColumns="True">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Machine" Binding="{Binding Name}" Width="*" />
                                <DataGridTextColumn Header="Wave" Binding="{Binding Wave}" Width="Auto" />
                                <DataGridTextColumn Header="Readiness" Binding="{Binding ReadinessText}" Width="Auto" />
                                <DataGridTextColumn Header="New deps (7d)" Binding="{Binding NewDeps7d}" Width="Auto" />
                                <DataGridTextColumn Header="Source" Binding="{Binding Source}" Width="Auto" />
                            </DataGrid.Columns>
                        </DataGrid>

                        <TextBlock Grid.Row="0" Grid.Column="1" Text="Unique flows (all machines)" FontWeight="SemiBold" Margin="2,0,0,4" />
                        <DataGrid Grid.Row="1" Grid.Column="1" x:CompileBindings="False"
                                  ItemsSource="{Binding Fleet.Flows}" IsReadOnly="True" CanUserResizeColumns="True"
                                  GridLinesVisibility="Horizontal" CanUserSortColumns="True">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Machine" Binding="{Binding Machine}" Width="Auto" />
                                <DataGridTextColumn Header="Direction" Binding="{Binding Direction}" Width="Auto" />
                                <DataGridTextColumn Header="Scope" Binding="{Binding RemoteScope}" Width="Auto" />
                                <DataGridTextColumn Header="Service" Binding="{Binding ServiceOrProcess}" Width="*" />
                                <DataGridTextColumn Header="Remote address" Binding="{Binding RemoteAddress}" Width="150" />
                                <DataGridTextColumn Header="R.Port" Binding="{Binding RemotePort}" Width="75" />
                                <DataGridTextColumn Header="Count" Binding="{Binding SampleCount}" Width="Auto" />
                            </DataGrid.Columns>
                        </DataGrid>

                        <TextBlock Grid.Row="2" Grid.Column="1" Text="Machine-to-machine dependencies" FontWeight="SemiBold" Margin="2,6,0,4" />
                        <DataGrid Grid.Row="3" Grid.Column="1" x:CompileBindings="False"
                                  ItemsSource="{Binding Fleet.CrossDependencies}" IsReadOnly="True" CanUserResizeColumns="True"
                                  GridLinesVisibility="Horizontal" CanUserSortColumns="True">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="From" Binding="{Binding FromMachine}" Width="*" />
                                <DataGridTextColumn Header="To" Binding="{Binding ToMachine}" Width="*" />
                                <DataGridTextColumn Header="Process" Binding="{Binding Process}" Width="*" />
                                <DataGridTextColumn Header="R.Port" Binding="{Binding RemotePort}" Width="75" />
                                <DataGridTextColumn Header="From wave" Binding="{Binding FromWave}" Width="Auto" />
                                <DataGridTextColumn Header="To wave" Binding="{Binding ToWave}" Width="Auto" />
                                <DataGridTextColumn Header="Count" Binding="{Binding SampleCount}" Width="Auto" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </DockPanel>
            </TabItem>

            <!-- FIREWALL -->
            <TabItem Header="Firewall">
                <DockPanel>
                    <Border DockPanel.Dock="Top" Background="#F3F4F6" Padding="12,8" Margin="0,0,0,8" CornerRadius="4">
                        <StackPanel Spacing="8">
                            <TextBlock Text="Reconcile observed connections against your firewall policy exports — resolve each remote IP to its firewall object/group, and classify every flow as Covered, Gap (no rule), or Denied. Find unused rules lists allow rules covering this machine that no observed flow exercised."
                                       Foreground="#374151" TextWrapping="Wrap" />
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <TextBlock Text="Policy folder" FontSize="11" Foreground="#6B7280" VerticalAlignment="Center" />
                                <TextBox Width="420" Text="{Binding Firewall.PolicyFolder}"
                                         Watermark="D:\Projects2026\CarrierMigrationMappingTool\assets\FW" />
                                <Button Content="Load policy" Command="{Binding Firewall.LoadPolicyCommand}" />
                                <TextBlock Text="{Binding Firewall.PolicyStatus}" VerticalAlignment="Center" Foreground="#374151" TextWrapping="Wrap" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <TextBlock Text="Server" FontSize="11" Foreground="#6B7280" VerticalAlignment="Center" />
                                <ComboBox MinWidth="220" ItemsSource="{Binding Firewall.MachineOptions}"
                                          SelectedItem="{Binding Firewall.SelectedMachine}" />
                                <TextBlock Text="Hours back" FontSize="11" Foreground="#6B7280" VerticalAlignment="Center" Margin="8,0,0,0" />
                                <NumericUpDown Width="120" Minimum="1" Maximum="8760" Value="{Binding Firewall.HoursBack}" />
                                <Button Content="Reconcile" Command="{Binding Firewall.ReconcileCommand}"
                                        Background="#1F2937" Foreground="White" />
                                <Button Content="Find unused rules" Command="{Binding Firewall.FindUnusedRulesCommand}" />
                                <TextBlock Text="Show" FontSize="11" Foreground="#6B7280" VerticalAlignment="Center" Margin="8,0,0,0" />
                                <ComboBox Width="110" ItemsSource="{Binding Firewall.CoverageOptions}"
                                          SelectedItem="{Binding Firewall.SelectedCoverage}" />
                                <Button Content="Export CSV" Command="{Binding Firewall.ExportCsvCommand}" />
                            </StackPanel>
                            <TextBlock Text="{Binding Firewall.ReconStatus}" Foreground="#374151" TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>
                    <DataGrid x:CompileBindings="False" ItemsSource="{Binding Firewall.Results}" IsReadOnly="True"
                              CanUserResizeColumns="True" GridLinesVisibility="Horizontal" CanUserSortColumns="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Coverage" Binding="{Binding Coverage}" Width="Auto" />
                            <DataGridTextColumn Header="Direction" Binding="{Binding Direction}" Width="Auto" />
                            <DataGridTextColumn Header="Remote address" Binding="{Binding RemoteAddress}" Width="150" />
                            <DataGridTextColumn Header="Firewall object" Binding="{Binding RemoteObject}" Width="*" />
                            <DataGridTextColumn Header="Groups" Binding="{Binding Groups}" Width="*" />
                            <DataGridTextColumn Header="Port" Binding="{Binding Port}" Width="Auto" />
                            <DataGridTextColumn Header="Proto" Binding="{Binding Protocol}" Width="Auto" />
                            <DataGridTextColumn Header="Service" Binding="{Binding Service}" Width="140" />
                            <DataGridTextColumn Header="Matching rule" Binding="{Binding Rule}" Width="*" />
                            <DataGridTextColumn Header="Rule #" Binding="{Binding RuleRef}" Width="Auto" />
                            <DataGridTextColumn Header="Policy" Binding="{Binding Policy}" Width="120" />
                            <DataGridTextColumn Header="Zones" Binding="{Binding Zones}" Width="Auto" />
                            <DataGridTextColumn Header="Count" Binding="{Binding Count}" Width="Auto" />
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </TabItem>

            <!-- SETTINGS -->
            <TabItem Header="Settings">
                <ScrollViewer>
                    <StackPanel Spacing="16" Margin="4" MaxWidth="720" HorizontalAlignment="Left">
                        <TextBlock Text="Collector service" FontSize="15" FontWeight="Bold" />
                        <Border Background="#F3F4F6" Padding="12" CornerRadius="4">
                            <StackPanel Spacing="10">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <TextBlock Text="Status:" FontWeight="SemiBold" VerticalAlignment="Center" />
                                    <TextBlock Text="{Binding Settings.ServiceStatus}" VerticalAlignment="Center" />
                                    <Button Content="Refresh" Command="{Binding Settings.RefreshServiceStatusCommand}" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Spacing="8" IsEnabled="{Binding IsLocalActive}">
                                    <Button Content="Install" Command="{Binding Settings.InstallServiceCommand}" />
                                    <Button Content="Start" Command="{Binding Settings.StartServiceCommand}" />
                                    <Button Content="Stop" Command="{Binding Settings.StopServiceCommand}" />
                                    <Button Content="Uninstall" Command="{Binding Settings.UninstallServiceCommand}" />
                                </StackPanel>
                                <TextBlock Text="Install/Start/Stop prompt for administrator elevation (UAC)."
                                           FontSize="11" Foreground="#6B7280" TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>

                        <TextBlock Text="Data source" FontSize="15" FontWeight="Bold" />
                        <StackPanel Spacing="4">
                            <TextBlock Text="Database path" FontSize="11" Foreground="#6B7280" />
                            <TextBox Text="{Binding Settings.DatabasePath}" />
                        </StackPanel>
                        <StackPanel Spacing="4">
                            <TextBlock Text="Export directory" FontSize="11" Foreground="#6B7280" />
                            <TextBox Text="{Binding Settings.ExportDirectory}" />
                        </StackPanel>
                        <CheckBox Content="Open folder after export (reveals the saved file in Explorer)"
                                  IsChecked="{Binding Settings.OpenFolderAfterExport}" />
                        <CheckBox Content="Keep full connection strings when scanning config (passwords still masked)"
                                  IsChecked="{Binding Settings.ConfigScanKeepRaw}" />
                        <StackPanel Spacing="4">
                            <TextBlock Text="Dashboard refresh (seconds)" FontSize="11" Foreground="#6B7280" />
                            <NumericUpDown Width="140" HorizontalAlignment="Left" Minimum="1" Maximum="300"
                                           Value="{Binding Settings.RefreshIntervalSeconds}" />
                        </StackPanel>
                        <Button Content="Apply settings" Command="{Binding Settings.ApplySettingsCommand}" HorizontalAlignment="Left" />
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

        </TabControl>
    </DockPanel>
</Window>
